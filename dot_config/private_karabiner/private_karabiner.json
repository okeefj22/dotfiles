{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Launch apps by right cmd+letters.",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "f",
                                    "modifiers": { "mandatory": ["right_command"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Firefox.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "w",
                                    "modifiers": { "mandatory": ["right_command"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/WezTerm.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "o",
                                    "modifiers": { "mandatory": ["right_command"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Microsoft Outlook.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": { "mandatory": ["right_command"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Microsoft Teams.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "v",
                                    "modifiers": { "mandatory": ["right_command"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Visual Studio Code.app'" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "m",
                                    "modifiers": { "mandatory": ["right_command"] }
                                },
                                "to": [{ "shell_command": "open '/Applications/Studio 3T.app'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper Key: Right Cmd → left shift + left option + left command + left control (held) or with ( when pressed alone",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "hyper_right_cmd",
                                            "value": 1
                                        }
                                    },
                                    {
                                        "key_code": "left_control",
                                        "modifiers": ["left_shift", "left_option", "left_command"]
                                    }
                                ],
                                "to_after_key_up": [
                                    {
                                        "set_variable": {
                                            "name": "hyper_right_cmd",
                                            "value": 0
                                        }
                                    }
                                ],
                                "to_if_alone": [
                                    {
                                        "key_code": "9",
                                        "modifiers": ["left_shift", "left_option", "left_command", "left_control"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "CTRL + HJKL to Arrow Keys",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": ["control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "left_arrow" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "j",
                                    "modifiers": {
                                        "mandatory": ["control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "down_arrow" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "k",
                                    "modifiers": {
                                        "mandatory": ["control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "up_arrow" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "l",
                                    "modifiers": {
                                        "mandatory": ["control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "right_arrow" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "shift+caps_lock->caps_lock; caps_lock+[...keys] -> control+[..keys]; caps_lock -> escape",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": {
                                        "mandatory": ["shift"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control" }],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "country_code": 0,
                "keyboard_type_v2": "ansi"
            }
        }
    ]
}