#!/usr/bin/env python3
"""
alias-insert <aliases-file> <section> <new-alias-line>

Inserts new-alias-line into the named section of aliases-file.
If the section doesn't exist, appends a new section at the end.
Exits with:
  0  success, prints "existing" or "new" to stdout
  1  error
"""
import sys
import re

if len(sys.argv) != 4:
    print(f"Usage: {sys.argv[0]} <aliases-file> <section> <new-alias-line>", file=sys.stderr)
    sys.exit(1)

filepath = sys.argv[1]
section  = sys.argv[2]
new_line = sys.argv[3]

with open(filepath) as f:
    lines = f.readlines()

header_pat = re.compile(r'^#\s*' + re.escape(section) + r'\s*$')
insert_idx = None

for i, line in enumerate(lines):
    if header_pat.match(line):
        # Scan forward to end of section (stop at blank line, next # header, or EOF)
        j = i + 1
        while j < len(lines) and lines[j].strip() and not lines[j].startswith('#'):
            j += 1
        insert_idx = j
        break

if insert_idx is not None:
    lines.insert(insert_idx, new_line + '\n')
    result = 'existing'
else:
    # Ensure file ends with a newline before appending
    if lines and not lines[-1].endswith('\n'):
        lines[-1] += '\n'
    lines.append('\n# ' + section + '\n' + new_line + '\n')
    result = 'new'

with open(filepath, 'w') as f:
    f.writelines(lines)

print(result)
